# AI Chat — OpenAI-compatible provider
# Copy this file to .env.local and fill in your values.

# Base URL of the OpenAI-compatible API endpoint.
# Leave blank to use the default OpenAI endpoint (https://api.openai.com/v1).
# Examples (must be OpenAI-compatible):
#   OpenAI:       (leave blank)
#   DeepSeek:     https://api.deepseek.com/v1
#   Groq:         https://api.groq.com/openai/v1
#   Ollama:       http://localhost:11434/v1
#   SiliconFlow:  https://api.siliconflow.cn/v1
#   Alibaba Qwen: https://dashscope.aliyuncs.com/compatible-mode/v1
AI_BASE_URL=

# API key for the provider above.
AI_API_KEY=

# Model ID to use. Must be available on the provider above.
# Examples: gpt-4o-mini, deepseek-chat, llama3-70b-8192, qwen3-max
AI_MODEL_ID=gpt-4o-mini